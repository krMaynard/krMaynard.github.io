---
layout: null
---
{%- assign posts = site.pages | where_exp: "p", "p.path contains 'blog/'" | where: "lang", "en" | where_exp: "p", "p.date" | sort: "date" | reverse -%}
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>Kieran Maynard — Blog</title>
    <description>Thoughts on product management, AI, compliance, and language.</description>
    <link>https://krmaynard.github.io/blog.html</link>
    <atom:link href="https://krmaynard.github.io/feed.xml" rel="self" type="application/rss+xml"/>
    <language>en-us</language>
    {% if posts.first.date %}<lastBuildDate>{{ posts.first.date | date_to_rfc822 }}</lastBuildDate>{% endif %}
{% for post in posts limit: 20 %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>https://krmaynard.github.io{{ post.url }}</link>
      <guid isPermaLink="true">https://krmaynard.github.io{{ post.url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <description>{{ post.description | xml_escape }}</description>
    </item>
{% endfor %}
  </channel>
</rss>
