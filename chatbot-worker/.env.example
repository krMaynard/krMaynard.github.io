# Chatbot worker configuration. Copy to `.env` for local dev (do not commit secrets).

# Required: Anthropic API key for the Claude Messages API.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to claude-opus-4-8).
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional: pull additional grounding sources from a PRIVATE GitHub repo
# (e.g. full résumé, detailed bio). A fine-grained token with read-only
# Contents access to that one repo is enough. Multiple files are supported
# via a comma-separated list of paths.
# GITHUB_TOKEN=github_pat_...
# GITHUB_SOURCES_REPO=krmaynard/private-bio
# GITHUB_SOURCES_PATHS=resume.md,bio.md

# Legacy single-file vars (still honored if the SOURCES_* vars are unset):
# GITHUB_RESUME_REPO=krmaynard/private-bio
# GITHUB_RESUME_PATH=resume.md

# Port (Cloud Run sets this automatically).
# PORT=8080
